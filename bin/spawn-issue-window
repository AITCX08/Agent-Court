#!/usr/bin/env bash
# Spawn-issue-window: 在 agent-court-dashboard tmux session 起一个新 window 跑 issue-resolver
# Claude CLI.
#
# 设计要点 (PR-13 review C1 fix):
# 1. 不用 shell `$(cat file)` 把 SKILL.md 嵌进命令字符串 (会被二次解析 + 注入风险)
# 2. 不用 `cat intro | claude` (stdin EOF 后 Claude 立即退出, window 没机会进入交互)
# 3. wrapper 写到独立目录, wrapper 内部用 bash 原生 $(<file) 读 skill, exec </dev/tty 保持 stdin
#
# Usage:
#   spawn-issue-window <repo> <num> <intro-file>
#
set -euo pipefail

REPO="${1:-}"
NUM="${2:-}"
INTRO_FILE="${3:-}"

if [ -z "$REPO" ] || [ -z "$NUM" ] || [ -z "$INTRO_FILE" ]; then
  echo "[spawn-issue-window] usage: spawn-issue-window <repo> <num> <intro-file>" >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PY_DIR="$REPO_ROOT/mcp/court-mcp"
PYTHON_BIN="$PY_DIR/.venv/bin/python3"
if [ ! -x "$PYTHON_BIN" ]; then
  PYTHON_BIN="python3"
fi

# SY-1 #16: 优先读 in-repo WORKFLOW.md (含 frontmatter), fallback 老 SKILL.md
# SY-2 #19: 同时读 working_dir_strategy + branch_prefix, 决定 court 工作目录是否走 worktree
# 用 workflow_loader 拿到 body (去 frontmatter), 喂给 Claude --append-system-prompt
WORKFLOW_PROMPT_FILE="$(mktemp "${TMPDIR:-/tmp}/agent-court-workflow-XXXXXX.md")"
WORKFLOW_META_FILE="$(mktemp "${TMPDIR:-/tmp}/agent-court-wf-meta-XXXXXX.txt")"
if ! ( cd "$PY_DIR" && "$PYTHON_BIN" -c "
from pathlib import Path
import sys
from workflow_loader import load_workflow, WorkflowNotFoundError
try:
    wf = load_workflow(Path('$REPO_ROOT'))
except WorkflowNotFoundError as e:
    print(f'[spawn-issue-window] {e}', file=sys.stderr)
    sys.exit(1)
Path('$WORKFLOW_PROMPT_FILE').write_text(wf.prompt_template, encoding='utf-8')
Path('$WORKFLOW_META_FILE').write_text(
    f'WORKING_DIR_STRATEGY={wf.config.working_dir_strategy}\n'
    f'BRANCH_PREFIX={wf.config.branch_prefix}\n'
)
print(f'[spawn-issue-window] workflow loaded from {wf.source_path}', file=sys.stderr)
" ); then
  rm -f "$WORKFLOW_PROMPT_FILE" "$WORKFLOW_META_FILE"
  exit 1
fi

# 解析 frontmatter meta 出 working_dir_strategy + branch_prefix
WORKING_DIR_STRATEGY="$(grep '^WORKING_DIR_STRATEGY=' "$WORKFLOW_META_FILE" | cut -d= -f2-)"
BRANCH_PREFIX="$(grep '^BRANCH_PREFIX=' "$WORKFLOW_META_FILE" | cut -d= -f2-)"
rm -f "$WORKFLOW_META_FILE"

if [ ! -f "$INTRO_FILE" ]; then
  echo "[spawn-issue-window] missing intro file: $INTRO_FILE" >&2
  rm -f "$WORKFLOW_PROMPT_FILE"
  exit 1
fi

# 用 Python helper 解析出 tmux window 名 (跟 dashboard_tmux.issue_window_name 一致)
WINDOW_NAME="$(cd "$PY_DIR" && "$PYTHON_BIN" -c "from dashboard_tmux import issue_window_name; print(issue_window_name('$REPO', int('$NUM')))")"

# SY-2 #19: working_dir_strategy=worktree → 给本 issue 起独立 git worktree, claude cwd 设为它
# inplace (默认) → cwd 用 ~/Desktop/K2Work/<repo_name>/ (老路径, prompt 里告诉 claude 自己 cd)
COURT_CWD=""
if [ "$WORKING_DIR_STRATEGY" = "worktree" ]; then
  REPO_NAME="${REPO##*/}"
  SOURCE_REPO="$HOME/Desktop/K2Work/$REPO_NAME"
  if [ ! -d "$SOURCE_REPO" ]; then
    echo "[spawn-issue-window] worktree strategy requires source repo at $SOURCE_REPO" >&2
    echo "[spawn-issue-window] git clone the repo first, or set working_dir_strategy=inplace in WORKFLOW.md" >&2
    rm -f "$WORKFLOW_PROMPT_FILE"
    exit 1
  fi
  COURT_CWD="$(cd "$PY_DIR" && "$PYTHON_BIN" -c "
from pathlib import Path
import sys
from workspace_manager import WorkspaceManager, WorkspaceError
try:
    wt = WorkspaceManager(branch_prefix='$BRANCH_PREFIX').create_worktree(
        Path('$SOURCE_REPO'), '$REPO#$NUM'
    )
except WorkspaceError as e:
    print(f'[spawn-issue-window] worktree creation failed: {e}', file=sys.stderr)
    sys.exit(1)
print(wt.path)
print(f'[spawn-issue-window] worktree at {wt.path} (branch={wt.branch})', file=sys.stderr)
")"
  if [ -z "$COURT_CWD" ]; then
    rm -f "$WORKFLOW_PROMPT_FILE"
    exit 1
  fi
fi

# 准备 wrapper 工作目录 (独立, 不污染 /tmp 全局)
WRAPPER_DIR="$(mktemp -d "${TMPDIR:-/tmp}/agent-court-issue-XXXXXX")"
cp "$WORKFLOW_PROMPT_FILE" "$WRAPPER_DIR/skill.md"
cp "$INTRO_FILE" "$WRAPPER_DIR/intro.txt"
echo "$COURT_CWD" > "$WRAPPER_DIR/cwd.txt"
rm -f "$WORKFLOW_PROMPT_FILE"
WRAPPER="$WRAPPER_DIR/run.sh"

cat > "$WRAPPER" <<'WRAPPER_EOF'
#!/usr/bin/env bash
# Wrapper 启动 claude CLI:
# - intro.txt 通过 process substitution 注入 stdin 作为第一段输入
# - exec </dev/tty 之后切到终端 tty, 保持 Claude REPL 不被 EOF kill
# - skill.md 通过 bash 原生 $(<file) 读取, 不走 shell 二次解析, 不会注入
# - cwd.txt 非空 → cd 进去 (SY-2 worktree 模式)
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
CWD_TARGET="$(<"$HERE/cwd.txt")"
if [ -n "$CWD_TARGET" ] && [ -d "$CWD_TARGET" ]; then
  cd "$CWD_TARGET"
fi
exec < <( cat "$HERE/intro.txt"; exec </dev/tty )
exec claude --append-system-prompt "$(<"$HERE/skill.md")"
WRAPPER_EOF
chmod +x "$WRAPPER"

# 起新 window. tmux new-window 的命令参数是一个完整 shell command, 但 "$WRAPPER" 是
# bash 已经 quote 过的路径, mktemp 生成的也只含安全字符 (字母数字 + .)
tmux new-window -t agent-court-dashboard -n "$WINDOW_NAME" "$WRAPPER"
