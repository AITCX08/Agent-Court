#!/usr/bin/env bash
# agent-yamen — pizhun (批准): list / approve / deny pending-approval
# messages awaiting human review. PR-5 entry point.
#
# Usage:
#   pizhun <project> list                 # show pending + expired
#   pizhun <project> approve <msg-id>     # release into peer inbox
#   pizhun <project> deny <msg-id>        # move into denied/
#   pizhun <project> cleanup              # auto-deny everything past timeout
#
# Audit trail lives at $YAMEN_ROOT/projects/<project>/logs/shenpi-log.jsonl
set -e

BIN="$(cd "$(dirname "$0")" && pwd)"
MCP_DIR="$(cd "$BIN/.." && pwd)/mcp/yamen-mcp"

VENV_PY="${YAMEN_VENV_PY:-$MCP_DIR/.venv/bin/python}"
if [ ! -x "$VENV_PY" ]; then
  echo "[pizhun] missing python venv at $VENV_PY" >&2
  echo "[pizhun] run: cd $MCP_DIR && uv venv .venv && uv pip install --python .venv/bin/python -e ." >&2
  exit 1
fi

exec "$VENV_PY" "$MCP_DIR/shenpi_cli.py" "$@"
